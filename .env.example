# ==========================================================================
# Customer Success Platform — environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# ==========================================================================

# ---- Postgres (used by the `db` service and the backend) ----
POSTGRES_USER=csp
POSTGRES_PASSWORD=csp_password
POSTGRES_DB=csp

# Backend DB URL (async driver). In Docker, host = `db`. For native dev, host = localhost.
DATABASE_URL=postgresql+asyncpg://csp:csp_password@db:5432/csp

# ---- Redis ----
# In Docker, host = `redis`. For native dev, host = localhost.
REDIS_URL=redis://redis:6379/0

# ---- JWT / Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh-cookie flags. Local: lax/false. Cross-domain prod (Vercel + Render):
# COOKIE_SAMESITE=none and COOKIE_SECURE=true (required so the browser sends it).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- AI provider (any OpenAI-compatible API) ----
# Leave AI_API_KEY empty to use the built-in heuristic fallback (app still works).
# Default below = Google Gemini Flash-Lite: cheapest model + most generous free
# daily quota, so production keeps producing real insights without billing.
#   Gemini:     AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  AI_MODEL=gemini-flash-lite-latest
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1                              AI_MODEL=openai/gpt-4o-mini
#   OpenAI:     AI_BASE_URL=https://api.openai.com/v1                                 AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_MODEL=gemini-flash-lite-latest
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ---- Email (SMTP) for password-reset links ----
# Leave SMTP_HOST empty in dev → the reset token is returned by the API instead
# of emailed (so the flow still works without an email account).
# Gmail example: host=smtp.gmail.com port=587 user=you@gmail.com password=<App Password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Base URL used to build the reset link in the email.
FRONTEND_URL=http://localhost:3004

# ---- App ----
# Comma-separated list of allowed CORS origins (the frontend).
CORS_ORIGINS=http://localhost:3000
DASHBOARD_CACHE_TTL_SECONDS=60

# ---- Frontend ----
# Browser-visible base URL of the backend API.
NEXT_PUBLIC_API_URL=http://localhost:8000
